# Шаблон .env для сервера деплоя
# Скопируйте на сервер: /opt/sauda/.env
#
# Перед первым деплоем также скопируйте:
#   docker-compose.yml          (из корня репозитория)
#   infrastructure/nginx/nginx.conf (монтируется compose-ом автоматически при деплое из git clone)

# ── Образы из GHCR (замените YOUR_ORG/sauda на ваш репозиторий) ──
BACKEND_IMAGE=ghcr.io/YOUR_ORG/sauda/sauda-api:dev-latest
FRONTEND_IMAGE=ghcr.io/YOUR_ORG/sauda/sauda-web:dev-latest

# ── Spring-профиль: dev | test | prod ──
SPRING_PROFILES_ACTIVE=dev

# ── База данных ──
DB_NAME=sauda_dev
DB_USER=sauda
DB_PASSWORD=CHANGE_ME

# ── Frontend (build arg; для pull готовых образов уже внутри) ──
VITE_API_URL=/api

# ── Nginx ──
NGINX_HTTP_PORT=80

# ── PROD: реальные интеграции (только для SPRING_PROFILES_ACTIVE=prod) ──
WHATSAPP_API_URL=
PAYMENT_PROVIDER_URL=
SUPPLIER_IMPORT_URL=
