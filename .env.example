# Конфигурация окружения Sauda
# Скопируйте в .env и укажите реальные значения
# cp .env.example .env

# Приложение
SPRING_PROFILES_ACTIVE=dev
NGINX_HTTP_PORT=80

# База данных
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sauda_dev
DB_USER=sauda
DB_PASSWORD=sauda

# Frontend
VITE_API_URL=/api

# Интеграции
WHATSAPP_API_URL=
PAYMENT_PROVIDER_URL=
SUPPLIER_IMPORT_URL=

# GHCR и сервер деплоя — только для CI/CD (GitHub Secrets, не здесь)
# Пока сервера нет: CD отключён (не задавайте DEPLOY_ENABLED в GitHub)
